# ROOD Manufacturing — environment variables
# Copy to .env.local for local dev, or set these in Vercel project settings.

# --- Lead notifications (Resend) ---
# Create a key at https://resend.com/api-keys
RESEND_API_KEY=
# Where new leads are emailed. Defaults to happyvwdude@gmail.com if unset.
LEAD_NOTIFY_TO=happyvwdude@gmail.com
# The "from" address. Must be a verified Resend domain/sender.
# Until you verify a domain, Resend allows onboarding@resend.dev.
LEAD_NOTIFY_FROM=ROOD Manufacturing <onboarding@resend.dev>

# --- Database (Postgres, e.g. Supabase or Vercel Postgres) ---
# Pooled connection string for the app.
DATABASE_URL=
# Direct (non-pooled) connection for Prisma migrations.
DIRECT_URL=

# --- Live inventory (Gearfire storefront) ---
# The live storefront we embed for real-time inventory.
NEXT_PUBLIC_STORE_URL=https://www.ar15rifleshop.com
